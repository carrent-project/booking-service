generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
}

model Booking {
  id         String       @id @default(uuid())
  userId     String
  carId      String
  startDate  DateTime
  endDate    DateTime
  totalPrice Int
  status     BookingStatus @default(PENDING)
  paymentUrl  String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@map("bookings")
}